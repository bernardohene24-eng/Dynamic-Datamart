# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_APP_NAME=Dynamic Datamart

# Backend Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/dynamic-datamart
DB_NAME=dynamic-datamart

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here

# Payment Gateway - Stripe
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Mobile Money APIs
# MTN Mobile Money
MTN_API_KEY=your_mtn_api_key
MTN_API_SECRET=your_mtn_api_secret
MTN_PRIMARY_KEY=your_mtn_primary_key
MTN_USER_ID=your_mtn_user_id

# Vodafone Cash
VODAFONE_API_KEY=your_vodafone_api_key
VODAFONE_API_SECRET=your_vodafone_api_secret
VODAFONE_MERCHANT_ID=your_vodafone_merchant_id

# AirtelTigo Money
AIRTELTIGO_API_KEY=your_airteltigo_api_key
AIRTELTIGO_API_SECRET=your_airteltigo_api_secret
AIRTELTIGO_MERCHANT_ID=your_airteltigo_merchant_id

# SMS Service
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Email Service
EMAIL_SERVICE=nodemailer
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password
SENDER_EMAIL=noreply@dynamicdatamart.com

# Social Media APIs
INSTAGRAM_ACCESS_TOKEN=your_instagram_token
TIKTOK_ACCESS_TOKEN=your_tiktok_token
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
FACEBOOK_ACCESS_TOKEN=your_facebook_token
YOUTUBE_API_KEY=your_youtube_api_key

# Virtual Numbers API
VIRTUAL_NUMBERS_PROVIDER=twilio
VIRTUAL_NUMBERS_API_KEY=your_virtual_numbers_api_key

# Admin Configuration
ADMIN_EMAIL=admin@dynamicdatamart.com
ADMIN_PASSWORD=change_this_password

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# Cors
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Redis (for caching and sessions)
REDIS_URL=redis://localhost:6379
REDIS_DB=0

# Analytics
GOOGLE_ANALYTICS_ID=UA_your_analytics_id
